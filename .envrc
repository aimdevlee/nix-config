# direnv configuration for nix-darwin development
# Automatically loads the development shell when entering the directory

# Use the flake's devShell
use flake

# Set up convenient aliases for this project
export NIX_CONFIG_DIR="/private/etc/nix-darwin"

# Project-specific environment variables
export FLAKE_PATH="."

# Add scripts directory to PATH
PATH_add ./scripts

# Show a message when entering the directory
echo "🛠️  Nix-Darwin development environment loaded"
echo "   Run 'check.sh' to validate configuration"
echo "   Run 'update.sh' to update flake inputs"
echo "   Run 'backup.sh' to backup configuration"